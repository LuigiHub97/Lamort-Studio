{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "build",
  "env": {
    "REACT_APP_API_URL": "https://lamort-api.onrender.com"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://lamort-api.onrender.com/api/:path*"
    }
  ]
}
